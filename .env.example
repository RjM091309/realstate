# MySQL (XAMPP / local) — copy this file to `.env` and adjust.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=realstate

# API server (Express). Vite (UI) uses port 5173; do not set Vite to the same port as API.
API_PORT=3001

# JWT signing (min 16 chars). Change for production.
JWT_SECRET=realstate-change-this-secret-key-32chars

# Optional: Gemini (existing app)
GEMINI_API_KEY=
